/*整体风格*/
QWidget
{
	font:12px "Microsoft YaHei";
	color:#2D2D2D;
	outline:none;
}


QLineEdit,QTextEdit,QComboBox,QPlainTextEdit,QTimeEdit,QDateEdit
{
	border:1px solid #E1E1E1;		
	border-radius:4px;
	padding-left:9px;
	padding-right:9px;
	background:#FFFFFF;
}

QLineEdit:hover,QTextEdit:hover,QComboBox:hover,QPlainTextEdit:hover,QTimeEdit:hover,QDateEdit:hover
{
	border-color:#0074C6;
}

QLineEdit:disabled,QTextEdit:disabled,QComboBox:disabled,QPlainTextEdit:disabled,QTimeEdit:disabled,QDateEdit:disabled
{
	background:#F1F2F3;
}

QLineEdit:read-only, QTextEdit:read-only, QComboBox:read-only, QPlainTextEdit:read-only, QTimeEdit:read-only, QDateEdit:read-only
{
	background:#F1F2F3;
}

QComboBox{
	padding-right:0;
}

QLineEdit{
    lineedit-password-character: 42;
}

QTimeEdit::up-button,QTimeEdit::down-button,QDateEdit::up-button,QDateEdit::down-button{
      width: 8px;
	  padding: 4px;
      border:0;
}

QTimeEdit::up-button,QDateEdit::up-button {
      image: url(:/Res/spinup_Normal.svg);
}

QTimeEdit::up-button:hover,QTimeEdit::up-button:pressed,QDateEdit::up-button:hover,QDateEdit::up-button:pressed
{
      image: url(:/Res/spinup_Press.svg);
}

QTimeEdit::up-button:disabled,QDateEdit::up-button:disabled {
      image: url(:/Res/spinup_Hover.svg);
}


QTimeEdit::down-button,QDateEdit::down-button {
      image: url(:/Res/spindown_Normal.svg);
}

QTimeEdit::down-button:hover,QTimeEdit::down-button:pressed,QDateEdit::down-button:hover,QDateEdit::down-button:pressed {
      image:url(:/Res/spindown_Press.svg);
}
  
QTimeEdit::down-button:disabled,QDateEdit::down-button:disabled {
      image:url(:/Res/spindown_Hover.svg);
}


QTabWidget::pane
{
	border:0;
	border-top:1px;
	border-style:solid;
	border-color:#E1E1E1;
	top:-1px;
}
QTabWidget::tab-bar {
}
QTabBar::tab{
	background:transparent;
	border:0;
	border-radius:0;
	min-width:45px;
	min-height:25px;
	margin-right:0;
}
QTabBar::tab:hover {
	color:#0074C6;
	border-bottom:1px solid #0074C6;
	padding-bottom:-1px;
}
QTabBar::tab:selected{
	color:#2384C8;
	border-bottom:1px solid #2384C8;
	padding-bottom:-1px;
}
QTabBar::tab:last {
	margin-left:0;
}
/*按钮*/
QToolButton,QPushButton{
	min-height:25px;
	border-radius:4px;
	border:1px solid #E1E1E1;
	color: #2D2D2D;
	padding-left:10px;
	padding-right:10px;
}
QPushButton{
	min-width:80px;
}
QToolButton:disabled,QPushButton:disabled
{
	border-color:#CDCDCD;
	color:#969696;
}
QToolButton:hover,QPushButton:hover
{
	border-color:#DEDEDE;
	background-color:#DEDEDE;
}
QToolButton:pressed,QToolButton:checked,QPushButton:pressed,QPushButton:checked
{
	border-color:#C8C8C8;
	background-color:#C8C8C8;
}
QToolButton::menu-button
{
	width:12px;
	border:none;
	image:none;
}
QToolButton::menu-button:hover,QToolButton::menu-button:pressed
{
	width:12px;
	border-left:1px solid #9B9B9B;
}
QToolButton::menu-arrow
{
	image:url(:/Res/down.svg);
}

QHeaderView{
	background-color:#F7F7F7;
}

QMenu
{
	border:1px solid #E1E1E1;
	background:#FFFFFF;
    padding-top:2px;
    padding-bottom:2px;
}
QMenu::item
{
    padding-left:30px;
    padding-right:22px;
    padding-top:5px;
    padding-bottom:5px;
}
QMenu::item:selected
{
    background-color:#e9ebf4;
}
QMenu::separator {
	height:1px;
	background-color:#E1E1E1;
    margin-left:30px;
    margin-right:10px;
}
QMenu::item:disabled
{
	color:#A0A0A0;
}
QMenu::indicator{
	width:22px;
	height:22px;
}

/*checkbox按钮风格*/
QMenu::indicator:non-exclusive:checked
{
    image:url(:/Res/action_checked.svg);
}
QMenu::indicator:non-exclusive:checked:selected
{
    image:url(:/Res/action_checked_hover.svg);
}


QCheckBox::indicator,QRadioButton::indicator{
	width: 16px;
	height: 16px;
}

QCheckBox::indicator:unchecked{ image:url(":/Res/checkbox_uncheck.svg"); }
QCheckBox::indicator:unchecked:hover{ image:url(":/Res/checkbox_uncheck_hover.svg"); }
QCheckBox::indicator:checked{ image:url(":/Res/checkbox_checked.svg"); }
QRadioButton::indicator:unchecked{ image:url(":/Res/radiobutton_uncheck.svg"); }
QRadioButton::indicator:unchecked:hover{ image:url(":/Res/radiobutton_hover.svg"); }
QRadioButton::indicator:checked{ image:url(":/Res/radiobutton_checked.svg"); }


/*表格*/
QHeaderView::section
{
	background:transparent;
	border:0;
	border-right:1px solid qlineargradient(spread:pad,x1:0.5,y1:0,x2:0.5,y2:1,
											stop:0 rgba(255,255,255,0),
											stop:0.2 rgba(255,255,255,0),
											stop:0.201 #C4C4C4,
											stop:0.799 #C4C4C4,
											stop:0.8 rgba(255,255,255,0),
											stop:1 rgba(255,255,255,0));
	border-bottom:1px solid #C4C4C4;
	min-height:30px;
	padding-right:6;
}
QHeaderView::section:hover {
	color:#0074C6;
}
QHeaderView::section:pressed {
	color:#2D2D2D;
	background-color:#0074C6;
	border-right-color:#0074C6;
	border-bottom-color:#0074C6;
	margin:1px;
}
QHeaderView::down-arrow
{
	margin-right:6px;
	min-width:18px;
	min-height:16px;
	image:url(:/Res/down.svg);
}
QHeaderView::up-arrow
{
	margin-right:6px;
	min-width:18px;
	min-height:16px;
	image:url(:/Res/up.svg);
}
 
/**********滚动条*********/
QScrollBar:horizontal{
	padding-left:0;
	padding-right:0;
	border:0 solid grey;
	background:transparent;
	height:10px;
	border-radius:4px;
}
QScrollBar:vertical{
	padding-top:0;
	padding-bottom:0;
	border:0 solid grey;
	background:transparent;
	width:10px;
	border-radius:4px;
}
QScrollBar::handle:vertical {
	background-color:#80C4C4C4;
	min-height:30px;
	border-radius:4px;
}
QScrollBar::handle:horizontal {
	background-color:#80C4C4C4;
	min-width:30px;
	border-radius:4px;
}
QScrollBar::handle:vertical:hover,QScrollBar::handle:horizontal:hover {
	background-color:#C4C4C4;
}
QScrollBar::add-line:vertical{
	height:3px;
	background:transparent;
}
QScrollBar::sub-line:vertical{
	height:3px;
	background:transparent;
}
QScrollBar::add-line:horizontal{
	width:0;
	subcontrol-position:left;
	subcontrol-origin:margin;
	background:transparent;
}
QScrollBar::sub-line:horizontal{
	width:0;
	subcontrol-position:right;
	subcontrol-origin:margin;
	background:transparent;
}
QScrollBar::up-arrow:vertical,QScrollBar::down-arrow:vertical,
QScrollBar::up-arrow:horizontal,QScrollBar::down-arrow:horizontal{
	border:0 solid grey;
	width:3px;
	height:3px;
	background:transparent;
}
QScrollBar::add-page:vertical,QScrollBar::sub-page:vertical,
QScrollBar::add-page:horizontal,QScrollBar::sub-page:horizontal{
	background:transparent;
	border-radius:4px;
}

/*listView*/
QListWidget,QListView{
	background:transparent;
	outline:0;	
	border-radius:0;
	padding:2px;
}
QListWidget::item,QListView::item{
	min-height:26px;
	max-height:26px;
}
QListWidget::item:hover,QListView::item:hover{
	background-color:#325BFF;
	color:#000000;
} 
QListWidget::item:selected,QListView::item:selected{
	color:#000000;
	background-color:#2384C8;
}
QListWidget::item:disabled ,QListView::item:disabled{
	background-color:transparent;
} 

/*QComboBox*/
QComboBox::drop-down
{
	width:20px;
	padding:6px;
	border:0;
	image:url(:/Res/down.svg);
}
QComboBox:!editable,QComboBox::drop-down:editable {
	background:transparent;
}

QComboBox QAbstractItemView{
	margin-top:1;
	outline:0;	
	border:1px solid #E1E1E1;
	background-color:#FFFFFF;
	selection-background-color:#0074C6;
	border-radius:4px;
}
QComboBox QAbstractItemView::item{
	padding-left:12px;
	padding-right:12px;
	min-height:30px;
	max-height:30px;
}
QComboBox QAbstractItemView::item:hover{
    background-color:#e9ebf4;
	color:#2D2D2D;
}
QComboBox QAbstractItemView::item:selected{
    background-color:#e9ebf4;
	color:#2D2D2D;
}

QTableWidget,QTableView,QTreeView,QTreeWidget{
	background:transparent;
	border:1px solid #C4C4C4;		
	border-radius:2px;
	outline:0;
	gridline-color:#C4C4C4;
	show-decoration-selected:1;
}
QTreeView::item,QTreeWidget::item{
	min-height:20px;
	max-height:20px;
}
QTableWidget::item,QTableView::item{
	min-height:30px;
	max-height:30px;
}
QTableWidget::item:selected,QTableView::item:selected,QTreeView::item:selected,QTreeWidget::item:selected{
	background-color:#FAD86F;
	color:#000000;
	margin:1px;
}
QAbstractItemView::indicator::unchecked{image:url(:/Res/checkbox_uncheck.svg);}
QAbstractItemView::indicator:unchecked:hover{image:url(:/Res/checkbox_uncheck_hover.svg);}
QAbstractItemView::indicator::checked{image:url(:/Res/checkbox_checked.svg);}



QGroupBox{
	border:1px solid #C4C4C4;
	margin-top:7px;
	border-radius:2px;
}
QGroupBox::title
{ 
	top:-7px;
	left:10px;
}

QSlider::add-page:vertical  {       
	background-color: #ABD9F5;  
}  
QSlider::sub-page:vertical   {  
	background-color: #3EADF5;
}  
QSlider::groove:vertical   {  
	background:transparent;  
	width:2px;  
}  
QSlider::handle:vertical   {  
	height: 12px;  
	width:12px;  
	border-image: url(:/Res/new/volume_thumb.svg) ;  
	/*由于槽（groove）只有2px，而滑块(handle)需要12px，则左右扩展5个px*/
	margin-left:-5px;   
	margin-right:-5px;
}  
QSlider::add-page:horizontal  {       
	background-color: #EEEEEE;
}  
QSlider::sub-page:horizontal   {  
	background-color: #3EADF5;
}  
QSlider::sub-page:horizontal:disabled   {  
	background-color: #EEEEEE;
}  
QSlider::groove:horizontal   {  
	background:transparent;  
	height:2px;  
}  
QSlider::handle:horizontal   {  
	height: 14px;  
	width: 14px;  
 	border-image: url(:/Res/slider_thumb.svg) ;
	/*由于槽（groove）只有2px，而滑块(handle)需要16px，则上下扩展7个px*/
	margin-top:-6px;   
	margin-bottom:-6px;
}  
QSlider::handle:horizontal:disabled   {  
 	border-image: url(:/Res/slider_thumb_disabled.svg) ;
}  

QProgressBar{
	border: 1px solid #E1E1E1;		
	border-radius:3px;
	text-align: center;
}

QProgressBar::chunk {
	background-color: #2384C8;
	border-radius: 3px;
}


QGifLabel{
	qproperty-speed: 8;
    qproperty-imageFile: url(":/Res/wait_white.svg");
}

CRLineEdit #clsBtn{
	min-width: 12px;
	min-height: 12px;
	border: 0px;
	padding: 8px;
	padding-right: 14px;
	padding-left: 2px;
	background-color: transparent;
	image: url(:/Res/clear.svg);
}
CRLineEdit #clsBtn:hover{image: url(:/Res/clear_hover.svg);}
CRLineEdit #clsBtn:pressed{image: url(:/Res/clear_pressed.svg);}
CRLineEdit #leftIcon{
	min-width: 12px;
	min-height: 12px;
	padding: 8px;
	padding-left: 14px;
	padding-right: 2px;
	image: url(:/Res/search_gray.svg);
}


/*QNoNCDialog*/
QNoNCDialog[dlgBorderType="0"]{
	border-image: none;
	border: 0px;
	background-color: rgb(255,255,255);
}

QNoNCDialog[dlgBorderType="1"]{
	border-image: none;
	border: 1px solid rgb(220,220,220);
	background-color: rgb(255,255,255);
}

QNoNCDialog[dlgBorderType="2"]{
	border-width: 9px;
	border-image: url(:/Res/shadow_rect.png);
	background-color:transparent; 
}


QNoNCDialog TitleBar{
	background-color:#F1F2F3;
	border:none;
	min-height:36px;
	max-height:36px;
}
QNoNCDialog TitleBar #titleText{
	padding-left:2px;
	font:12px;
}

QNoNCDialog TitleBar QToolButton,CRSearchTitleBar QToolButton{
	border:0;
	border-radius:0;
	padding: 0px;
	min-width:36px;
	max-width:36px;
        qproperty-iconSize: 14px 14px;
}
QNoNCDialog TitleBar #titleCloseBtn{
	qproperty-icon: url(:/Res/dialog_close.svg);
}
QNoNCDialog TitleBar #titleMinBtn{
	qproperty-icon: url(:/Res/dialog_min.svg);
}
QNoNCDialog TitleBar #titleMaxBtn{
	qproperty-icon: url(:/Res/dialog_max.svg);
}
QNoNCDialog TitleBar #titleRestoreBtn{
	qproperty-icon: url(:/Res/dialog_restore.svg);
}

/*********提示框*******/
CRMsgBox #CRMsg_label{
	margin: 20px;
	margin-top: 35px;
	margin-bottom: 35px;
}
CRMsgBox #frameBtns QToolButton,CRMsgBox #frameBtns QPushButton{
	min-height: 30px;
	max-height: 30px;
	padding-left: 10px;
	padding-right: 10px;
	min-width: 70px;
	max-width: 70px;
}

/********** 红点提示器 **********/
#NewDatRedTip{
	min-width: 8px;
	max-width: 8px;
	min-height: 8px;
	max-height: 8px;
	border-radius: 4px;
	background-color:#FF0000;
}


/********** IMDemo 全局搜索区域 **********/
MainDialog #gSearchWidget{
	min-height:65px;
	max-height:65px;
	border-bottom:1px solid #E1E1E1;
}
MainDialog #searchEdt{
	min-height:34px;
	max-height:34px;
	background: #F0F0F0;
	border-radius: 4px;
	border: 0px;
	qproperty-leftIconVisible: true;
}
MainDialog #searchEdt:focus{
	background: white;
	border: 1px solid #F0F0F0;
}

MainDialog #gSearchWidget #addBtn{
	min-width:34px;
	max-width:34px;
	min-height:34px;
	max-height:34px;
    padding-left: 0px;
    padding-right: 0px;
	background-color: transparent;
    border: 0px;
	qproperty-iconSize: 14px 14px;
	qproperty-icon:url(":/Res/titleNewBtn.svg");
	background-color:#EAEAEA;
}

MainDialog #gSearchWidget #addBtn:hover{
	background-color:#DEDEDE;
}

MainDialog #gSearchWidget #addBtn:pressed{
	background-color:#C8C8C8;
}

MainDialog #lbMsgUnreadCount
{
	border: 0px;
	border-radius: 7px;
	min-height: 14px;
	max-height: 14px;
	padding-left: 4px;
	padding-right: 4px;
	background-color: #FF2525;
	color: white;
	font-size: 10px;
	margin-top: 5px;
	margin-right: 12px;
}

MainDialog #friendsBtn>#NewDatRedTip{
	margin-top: 10px;
	margin-right: 20px;
}

/* LoginDlg */
LoginDlg #loginDlgTitleBar{
	background-color:transparent;
	border:0;
    padding-right: 10px;
}
LoginDlg{
	min-width:420px;
	max-width:420px;
	min-height:660px;
	max-height:660px;
}
LoginDlg *{
	 font:14px; 
}
LoginDlg #btns QPushButton,LoginDlg #btnCancelLogin
{
	min-height:36px;
	max-height:36px;
}
LoginDlg #lbl_version,LoginDlg #lbl_otherMethod
{
    color: #999999;
}
LoginDlg #line1,LoginDlg #line2{
	min-height: 1px;
	max-height: 1px;
	background-color: #DCDCDC;
}

LoginDlg #btnSetting{
    qproperty-icon:url(:/Res/loginSetting.svg);	
}

LoginDlg #btnBack{
    qproperty-icon:url(:/Res/back_Normal.svg);
	min-width: 100px;
	max-width: 100px;
}

LoginDlg #stackedWidget{
	min-width:320px;
	max-width:320px;
}

LoginPage #loginLogo{
	min-height:180px;
	max-height:180px;
    image:url(:/Res/logo.svg);
}

LoginPage #label_version{
	padding-top: 30px;
	color: #888;
}

LoginPage #label_1{
	font:22px;
}
LoginPage #label_2, LoginPage #labelDefAuthCode{
	color: #969696;
}

LoginPage #acntWidget, LoginPage #authCodeWidget{
	border: none;
	border-bottom:1px solid #E1E1E1;
}

LoginPage #label_3{
	border: none;
	padding-right: 9px;
	border-right:1px solid #E1E1E1;
}

LoginPage #phoneNumber, LoginPage #authCode{
	padding-left: 3px;
	padding-right: 6px;
	border: none;
}
LoginPage #editAccount, LoginPage #editPassword{
	padding-left: 3px;
	padding-right: 6px;
	min-height: 48px;
	max-height: 48px;
	border: 1px solid #E1E1E1;
}

LoginPage #editAccount:focus, LoginPage #editPassword:focus{
	border-color:  #3981FC;
}

LoginPage #getAuthCodeBtn,LoginPage #swtichPwdPageBtn, LoginPage #swtichAuthCodePageBtn{
	border: none;
	background: none;
	padding: 0px;
	color: #3981FC;
}
LoginPage #getAuthCodeBtn:hover, LoginPage #swtichPwdPageBtn:hover, LoginPage #swtichAuthCodePageBtn:hover{
	background: none;
	color: #035AEB;
}

LoginPage #getAuthCodeBtn:pressed, LoginPage #swtichPwdPageBtn:pressed, LoginPage #swtichAuthCodePageBtn:pressed{
	color: #3981FC;
}

LoginPage #authCodeLoginBtn, LoginPage #pswdLoginBtn, LoginSettingPage #resetBtn{
	border-color:#3981FC;
	background-color:#3981FC;
	color:#FFFFFF;
	min-height:35px;
	max-height:35px;
}
LoginPage #authCodeLoginBtn:hover, LoginPage #pswdLoginBtn:hover, LoginSettingPage #resetBtn:hover{
	border-color:#035AEB;
	background-color:#035AEB;
}
LoginPage #authCodeLoginBtn:pressed, LoginPage #pswdLoginBtn:pressed, LoginSettingPage #resetBtn:pressed{
	border-color:#3981FC;
	background-color:#3981FC;
}
LoginSettingPage QLabel{
	min-height:35px;
	max-height:35px;
}

QNoNCDialog CRDialogBtns{
	background-color: transparent;
	min-height:25px;
	max-height:65535px;
}


/* MainDialog */
MainDialog #mainLeftBar{
	min-width: 64px;
	max-width: 64px;
	background-color: #EBEBEB;
	border-right: 1px solid #DCDCDC;
}


#mainLeftBar QToolButton
{
	border:none;
	border-radius:0;
	max-height:55px;
	min-height:55px;
	background:transparent;
	qproperty-iconSize: 32px 32px;
	color:#444444;
	padding:6px;
	padding-bottom:5px;
}

uConnectClient #myselBtn
{
	max-width: 32px;
	min-width: 32px;
	qproperty-iconSize: 32px 32px;
	padding: 0;
    background: none;
    border: 0;
}


#mainLeftBar QToolButton[isHover=true]
{
	color:#2384C8;
}
#mainLeftBar QToolButton[isChecked=true]
{
	color:#2384C8;
}

#mainLeftBar #messageBtn{
	qproperty-icon:url(":/Res/msg_gray.svg");
}
#mainLeftBar #messageBtn[isHover=true], #mainLeftBar #messageBtn[isChecked=true]
{
	qproperty-icon:url(":/Res/msg_blue.svg");
}

#mainLeftBar #friendsBtn{
	qproperty-icon:url(":/Res/friends_gray.svg");
}
#mainLeftBar #friendsBtn[isHover=true], #mainLeftBar #friendsBtn[isChecked=true]
{
	qproperty-icon:url(":/Res/friends_blue.svg");
}

#mainLeftBar #groupBtn{
	qproperty-icon:url(":/Res/group_gray.svg");
}
#mainLeftBar #groupBtn[isHover=true], #mainLeftBar #groupBtn[isChecked=true]
{
	qproperty-icon:url(":/Res/group_blue.svg");
}

#mainLeftBar #moreBtn{
	qproperty-icon:url(":/Res/more_gray.svg");
}
#mainLeftBar #moreBtn[isHover=true], #mainLeftBar #setBtn[isChecked=true]
{
	qproperty-icon:url(":/Res/more_blue.svg");
}



/******************会话列表**********************/
MessageMgrPage #msgLeftBar{
	border: 0px;
	border-right: 1px solid #EDEDED;
	min-width: 246px;
	max-width: 246px;
}
MessageMgrPage #sessionList{
	background: transparent;
	border: 0px;
	padding: 0px;
	margin: 0px;
	border-right: 1px solid #EDEDED;
}
MessageMgrPage #sessionList::item {
	min-height: 65px;
	max-height: 65px;
}
MessageMgrPage #sessionList::item:hover{
	background-color: #F4F5F6;
}
MessageMgrPage #sessionList::item:selected{
	background-color: #E9EBF4;
}
MessageMgrPage #lbNoMessage{
	image: url(:/Res/no_content.svg);
	min-width:250px;
	min-height:100px;
}
SessionItemWidget #lbMsgNote{
	color: #DD2B2B;
}
SessionItemWidget #lbLastTime,SessionItemWidget #lbLastMsg{
	color: #999999;
}
SessionItemWidget #lbName{
	font-size: 14px;
	color: #333333;
}
SessionItemWidget #lbUnRead{
	border: 0px;
	min-width: 12px;
	min-height: 16px;
	max-height: 16px;
	padding-left: 2px;
	padding-right: 2px;
