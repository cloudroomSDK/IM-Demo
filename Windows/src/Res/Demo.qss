	border: 0px;
}
MeetingMainDialog #btnExit{
	qproperty-iconSize: 46px 46px;
	qproperty-icon: url(:/Res/hangUp.svg);
}
#ImCalloutDlg #btnExit[isHover=true]{
	qproperty-icon: url(:/Res/hangUp_hover.svg);
}

MeetingMainDialog #btnMic, MeetingMainDialog #btnVideo{
	qproperty-iconSize: 36px 36px;
}
